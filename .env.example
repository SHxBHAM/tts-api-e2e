# Copy to .env on the box and fill in. start.sh auto-loads this.
#   cp .env.example .env && nano .env

# --- required ---
HF_REPO=Shxbhxm21/voxcpm2-hinglish-lora   # HF repo with lora_only/ + reference.wav
API_TOKEN=                                 # shared bearer token teammates send
HF_TOKEN=                                  # HF read token (LoRA repo is private)

# --- recommended ---
HF_HOME=/workspace/hf                      # persist the ~3GB base model across restarts
PORT=8000                                  # open this port in the E2E firewall/security group

# --- optional (sane defaults in server.py) ---
# LORA_STEP=100
# DEFAULT_CFG=2.0
# DEFAULT_TIMESTEPS=10
# DEFAULT_BITRATE=128
# MAX_BATCH=200
# ASSET_DIR=/workspace/assets
